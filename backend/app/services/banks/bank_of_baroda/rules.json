{
  "schema_version": 1,
  "bank_key": "bank_of_baroda",
  "source_class": "app.services.banks.bank_of_baroda.rule_engine.BankOfBarodaRuleEngine",
  "match_semantics": {
    "layers": [
      "exact_keyword",
      "pattern_match",
      "upi_merchant",
      "amount_heuristic",
      "generic_fallback",
      "default"
    ],
    "is_debit": "debit_truthy",
    "upi_gate": "upi_or_at",
    "upi_debit_only": true,
    "return_mode": "split",
    "generic_fallback": true
  },
  "confidence": {
    "exact": 0.99,
    "pattern": 0.95,
    "merchant": 0.90,
    "upi": 0.85,
    "amount": 0.70,
    "default": 0.50
  },
  "defaults": {
    "debit_category": "Others Debit",
    "credit_category": "Others Credit"
  },
  "upi_merchants": {
    "swiggy": "Food",
    "zomato": "Food",
    "dominos": "Food",
    "mcdonalds": "Food",
    "pizza": "Food",
    "amazon": "Shopping",
    "flipkart": "Shopping",
    "myntra": "Shopping",
    "meesho": "Shopping",
    "snapdeal": "Shopping",
    "irctc": "Travel",
    "makemytrip": "Travel",
    "goibibo": "Travel",
    "redbus": "Travel",
    "petrol": "Fuel",
    "diesel": "Fuel",
    "fuel": "Fuel",
    "hpcl": "Fuel",
    "bpcl": "Fuel",
    "iocl": "Fuel"
  },
  "amount_heuristics": {
    "atm": {
      "enabled": true,
      "multiple_of": 100,
      "min_amount": 500,
      "max_amount": 50000,
      "description_tokens": ["ATM", "ATW", "CASH WITHDRAWAL"],
      "category": "ATM Withdrawal",
      "matched_rule": "amount_atm"
    },
    "emi": {
      "enabled": true,
      "debit_only": true,
      "min_amount": 500,
      "max_amount": 100000,
      "multiple_of": 100,
      "description_tokens": [
        "emi",
        "loan",
        "installment"
      ],
      "category": "Loan Payment",
      "matched_rule": "amount_emi",
      "token_case": "lower"
    },
    "salary": {
      "enabled": true,
      "credit_only": true,
      "min_amount": 10000,
      "multiple_of": 1000,
      "description_tokens": [
        "salary",
        "payroll",
        "wages"
      ],
      "category": "Salary",
      "matched_rule": "amount_salary",
      "token_case": "lower"
    }
  },
  "debit_rules": {
    "ATM Withdrawal": {
      "exact": ["ATM CASH", "ATM/CASH", "CASH WITHDRAWAL"],
      "patterns": ["\\bATM\\s*WDL\\b"]
    },
    "Bank Charges": {
      "exact": ["CHARGES FOR", "ANNUAL MAINTENANCE", "GST CHARGES"],
      "patterns": []
    },
    "Bounce": {
      "exact": [
        "CHEQUE RETURN",
        "CHQ RETURN",
        "RETURN CHARGES",
        "RTNCHG",
        "NACH BOUNCE",
        "ECS BOUNCE",
        "ACH RETURN",
        "NACH RETURN",
        "ECS RETURN",
        "MANDATE RETURN",
        "SI RETURN",
        "CHEQUE DISHONOUR",
        "DISHONOURED CHEQUE",
        "INSUFFICIENT FUNDS",
        "INSUFF FUNDS",
        "PAYMENT RETURNED",
        "DEBIT RETURN",
        "OUTWARD BOUNCE",
        "O/W RETURN",
        "OUTW RETURN",
        "CHQ BOUNCE",
        "CHEQUE BOUNCE",
        "Bounce CHGS",
        "RETURN UNPAID"
      ],
      "patterns": [
        "(O/W|OUTW|OUTWARD)\\s*(RETURN|RET|CHQ RET)",
        "(CHQ|CHEQUE)\\s*(RETURN|RET|DISHONOUR|BOUNCE)",
        "(NACH|ECS|ACH)\\s*(RETURN|RET|BOUNCE)",
        "(MANDATE|SI)\\s*RETURN",
        "RETURN\\s*(CHGS|CHARGES)",
        "BOUNCE\\s*(CHGS|CHARGES|CHARGE)",
        "PENAL\\s*(CHARGE|CHGS)",
        "PENALTY\\s*(CHARGE|CHGS)"
      ]
    },
    "Insurance": {
      "exact": ["LIC PREMIUM", "LICPREMIUM", "LIC POLICY", "INSURANCE", "HDFC LIFE", "ICICI PRU", "SBI LIFE"],
      "patterns": [".*INSURANCE.*PREMIUM.*", "LIC.*PREMIUM"]
    },
    "Loan Payment": {
      "exact": [
        "INSTALLMENT",
        "LOAN REPAYMENT",
        "NACH DR",
        "ECS DR",
        "TVSCREDITSERVICESLTD",
        "IDFC FIRST",
        "BAJAJ FINANCE",
        "BAJAJ FINSERV"
      ],
      "patterns": ["\\bECS\\s*DR\\b", "\\bNACH\\s*DR\\b", "\\bEMI\\b"]
    },
    "Credit Card Payment": {
      "exact": [
        "CREDIT CARD",
        "CC PAYMENT",
        "CCPAYMENT",
        "CREDITCARD PAYMENT",
        "CREDIT CARD PAYMENT",
        "CARD PAYMENT",
        "CARD BILL",
        "ONECARD",
        "CRED",
        "SLICE"
      ],
      "patterns": [
        "CreditCard\\s*Payment.*",
        "CC\\s*PAYMENT.*",
        ".*CARD\\s*BILL.*",
        ".*CREDIT\\s*CARD.*"
      ]
    },
    "Food": {
      "exact": ["SWIGGY", "ZOMATO", "DOMINOS", "MCDONALDS", "BURGER KING", "PIZZA HUT", "KFC"],
      "patterns": ["\\bSWIGGY\\b", "\\bZOMATO\\b"]
    },
    "Shopping": {
      "exact": ["AMAZON", "FLIPKART", "MYNTRA", "MEESHO", "SNAPDEAL"],
      "patterns": ["\\bPOS\\s+\\d{6}"]
    },
    "Entertainment": {
      "exact": ["NETFLIX", "HOTSTAR", "PRIME VIDEO", "SPOTIFY", "SONYLIV", "ZEE5"],
      "patterns": ["\\bNETFLIX\\b", "\\bSPOTIFY\\b"]
    },
    "Travel": {
      "exact": ["IRCTC", "MAKEMYTRIP", "GOIBIBO", "REDBUS"],
      "patterns": ["\\bIRCTC\\b"]
    },
    "Transport": {
      "exact": ["UBER", "OLA", "FASTAG", "RAPIDO"],
      "patterns": ["\\bFASTAG\\b"]
    },
    "Fuel": {
      "exact": ["PETROL", "DIESEL", "FUEL", "HPCL", "BPCL", "IOCL", "INDIAN OIL"],
      "patterns": ["\\bPETROL\\b", "\\bDIESEL\\b"]
    },
    "Bill Payment": {
      "exact": ["ELECTRICITY", "AIRTEL", "JIO", "BROADBAND", "WATER BILL", "GAS BILL", "DTH"],
      "patterns": ["\\bELECTRICITY\\b", "\\bBROADBAND\\b"]
    },
    "Education": {
      "exact": ["FEES", "TUITION", "SCHOOL FEES", "COLLEGE"],
      "patterns": ["\\bTUITION\\b", ".*FEES.*"]
    },
    "Investment": {
      "exact": ["DIVIDEND", "MUTUAL FUND", "SIP"],
      "patterns": ["\\bSIP\\b", ".*MUTUAL.*FUND.*"]
    },
    "Transfer": {
      "exact": ["MONTHLY TRANSFER", "SELF TRANSFER"],
      "patterns": [
        "^IMPS/P2A/\\d+/?\\d*$",
        "^NEFT/[A-Z0-9]+/\\d+$",
        "^RTGS/[A-Z0-9]+/\\d+$"
      ]
    },
    "Cheque": {
      "exact": [],
      "patterns": ["\\bCHQPAID\\b|\\bCHEQUE PAID\\b"]
    }
  },
  "credit_rules": {
    "Inward Bounce": {
      "exact": [
        "I/W RETURN",
        "INWARD RETURN",
        "INW RETURN",
        "INW RET",
        "CHQ DEP RETURN",
        "CHEQUE DEP RETURN",
        "CHEQUE DEPOSIT RETURN",
        "CHEQUE RETURNED",
        "RETURNED CHEQUE",
        "CREDIT RETURN",
        "DEPOSIT RETURN",
        "INWARD BOUNCE",
        "INW BOUNCE",
        "CLG RETURN",
        "CLEARING RETURN"
      ],
      "patterns": [
        "(I/W|INW|INWARD)\\s*(RETURN|RET|CHQ RET|BOUNCE)",
        "(CLG|CLEARING)\\s*(RETURN|RET)"
      ]
    },
    "Salary": {
      "exact": ["SALARY", "SAL CR", "PAYROLL", "WAGES", "STIPEND"],
      "patterns": ["SALARY.*", "SAL.*CREDIT.*", "PAYROLL.*"]
    },
    "Cash Deposit": {
      "exact": ["BY CASH", "CASH DEPOSIT"],
      "patterns": []
    },
    "Refund": {
      "exact": ["REVERSAL", "REFUND", "CASHBACK"],
      "patterns": ["\\bREFUND\\b", "\\bREVERSAL\\b"]
    },
    "Interest Income": {
      "exact": ["INT CR", "INTEREST CREDIT", "INT."],
      "patterns": [".*INTEREST.*CREDIT.*"]
    },
    "Loan Credit": {
      "exact": ["LOAN", "DISBURSAL", "LOAN DISBURSAL", "LOAN CREDIT", "DISBURSEMENT"],
      "patterns": ["LOAN.*DISBURSAL", "LOAN.*CR"]
    },
    "Investment": {
      "exact": ["DIVIDEND"],
      "patterns": []
    },
    "Transfer": {
      "exact": ["NEFT", "RTGS", "IMPS", "UPI"],
      "patterns": ["(IMPS|NEFT|RTGS|UPI)[/:-]"]
    }
  }
}
