{
  "schema_version": 1,
  "bank_key": "idfc",
  "source_class": "app.services.banks.idfc.rule_engine.IDFCRuleEngine",
  "match_semantics": {
    "layers": [
      "exact_keyword",
      "pattern_match",
      "upi_merchant",
      "amount_heuristic",
      "generic_fallback",
      "default"
    ],
    "is_debit": "debit_truthy",
    "upi_gate": "upi_or_at",
    "upi_debit_only": true,
    "return_mode": "split",
    "generic_fallback": true
  },
  "confidence": {
    "exact": 0.99,
    "pattern": 0.95,
    "merchant": 0.90,
    "upi": 0.85,
    "amount": 0.70,
    "default": 0.50
  },
  "defaults": {
    "debit_category": "Others Debit",
    "credit_category": "Others Credit"
  },
  "upi_merchants": {
    "swiggy": "Food",
    "zomato": "Food",
    "dominos": "Food",
    "mcdonalds": "Food",
    "pizza": "Food",
    "amazon": "Shopping",
    "flipkart": "Shopping",
    "myntra": "Shopping",
    "meesho": "Shopping",
    "irctc": "Travel",
    "makemytrip": "Travel",
    "goibibo": "Travel",
    "redbus": "Travel",
    "petrol": "Fuel",
    "diesel": "Fuel",
    "fuel": "Fuel",
    "hpcl": "Fuel",
    "bpcl": "Fuel",
    "iocl": "Fuel",
    "uber": "Transport",
    "ola": "Transport",
    "rapido": "Transport",
    "fastag": "Transport"
  },
  "debit_rules": {
    "Loan Payment": {
      "exact": [
        "NACH/BAJAJ FINANCE",
        "NACH/TVSCREDITSERVICES",
        "TVS CREDIT SERVICES",
        "NACH/SHRIRAMCITYUNIONFINA",
        "NACH/SHUHARITECHVENTURES",
        "NACH/1T9 TECHNOLOGY PVT L",
        "NACH/WESTERN CAPITAL ADVI",
        "EMI",
        "LOAN",
        "BAJAJ FINANCE",
        "HOME LOAN",
        "LIC HOUSING",
        "INSTALLMENT"
      ],
      "patterns": [
        "NACH.*DEBIT.*",
        "ECS.*DEBIT.*",
        ".*EMI.*",
        ".*LOAN.*REPAY.*"
      ]
    },
    "Credit Card Payment": {
      "exact": [
        "CREDIT CARD",
        "CC PAYMENT",
        "CCPAYMENT",
        "CREDITCARD PAYMENT",
        "CREDIT CARD PAYMENT",
        "CARD PAYMENT",
        "CARD BILL",
        "ONECARD",
        "ONECARD@IDFCBANK",
        "CRED",
        "SLICE",
        "IDFC POWER CARD"
      ],
      "patterns": [
        "CreditCard\\s*Payment.*",
        "CC\\s*PAYMENT.*",
        ".*CARD\\s*BILL.*",
        ".*CREDIT\\s*CARD.*",
        ".*ONECARD.*"
      ]
    },
    "Bounce": {
      "exact": [
        "CHEQUE RETURN",
        "CHQ RETURN",
        "RETURN CHARGES",
        "RTNCHG",
        "NACH BOUNCE",
        "ECS BOUNCE",
        "ACH RETURN",
        "NACH RETURN",
        "ECS RETURN",
        "MANDATE RETURN",
        "SI RETURN",
        "CHEQUE DISHONOUR",
        "DISHONOURED CHEQUE",
        "INSUFFICIENT FUNDS",
        "INSUFF FUNDS",
        "PAYMENT RETURNED",
        "DEBIT RETURN",
        "OUTWARD BOUNCE",
        "O/W RETURN",
        "OUTW RETURN",
        "CHQ BOUNCE",
        "CHEQUE BOUNCE",
        "Bounce CHGS",
        "RETURN UNPAID"
      ],
      "patterns": [
        "(O/W|OUTW|OUTWARD)\\s*(RETURN|RET|CHQ RET)",
        "(CHQ|CHEQUE)\\s*(RETURN|RET|DISHONOUR|BOUNCE)",
        "(NACH|ECS|ACH)\\s*(RETURN|RET|BOUNCE)",
        "(MANDATE|SI)\\s*RETURN",
        "RETURN\\s*(CHGS|CHARGES)",
        "BOUNCE\\s*(CHGS|CHARGES|CHARGE)",
        "PENAL\\s*(CHARGE|CHGS)",
        "PENALTY\\s*(CHARGE|CHGS)"
      ]
    },
    "Bank Charges": {
      "exact": ["CHARGE:AMB NON-MAINTENANCE"],
      "patterns": []
    },
    "Tax Payment": {
      "exact": ["CGST ON CHARGE", "SGST ON CHARGE"],
      "patterns": []
    },
    "Transfer": {
      "exact": [
        "IMPS-MOB/FUND TRF",
        "IMPS-INET/FUND TRF",
        "NEFT/",
        "PAY BY WHATSAPP",
        "PAYMENT FROM PHONEPE",
        "UPI TRANSACTION FOR PPPL",
        "MANDATE REQUEST"
      ],
      "patterns": []
    },
    "Shopping": {
      "exact": [
        "PAY TO BHARATPE MERCHANT",
        "PAY TO R K S MOBILE SHOPPEE"
      ],
      "patterns": []
    },
    "ATM Withdrawal": {
      "exact": ["ATM CASH WITHDRAWAL", "ATM WDL", "ATM/CASH", "NFS-CWDR", "CASH WITHDRAWAL"],
      "patterns": ["\\bATM\\s*WDL\\b", "\\bNFS[-/]CWDR\\b"]
    },
    "Food": {
      "exact": ["SWIGGY", "ZOMATO", "DOMINOS", "MCDONALDS", "BURGER KING", "PIZZA HUT", "KFC"],
      "patterns": ["\\bSWIGGY\\b", "\\bZOMATO\\b"]
    },
    "Transport": {
      "exact": ["UBER", "OLA", "FASTAG", "RAPIDO"],
      "patterns": ["\\bFASTAG\\b"]
    },
    "Fuel": {
      "exact": ["PETROL", "DIESEL", "FUEL", "HPCL", "BPCL", "IOCL", "INDIAN OIL"],
      "patterns": ["\\bPETROL\\b", "\\bDIESEL\\b"]
    },
    "Entertainment": {
      "exact": ["NETFLIX", "HOTSTAR", "PRIME VIDEO", "SPOTIFY", "SONYLIV", "ZEE5"],
      "patterns": ["\\bNETFLIX\\b", "\\bSPOTIFY\\b"]
    },
    "Bill Payment": {
      "exact": ["ELECTRICITY", "WATER BILL", "GAS BILL", "AIRTEL", "JIO", "BROADBAND", "DTH"],
      "patterns": ["\\bELECTRICITY\\b", "\\bBROADBAND\\b"]
    },
    "Insurance": {
      "exact": ["LIC PREMIUM", "LICPREMIUM", "INSURANCE", "HDFC LIFE", "ICICI PRU", "SBI LIFE"],
      "patterns": [".*INSURANCE.*PREMIUM.*", "LIC.*PREMIUM"]
    },
    "Investment": {
      "exact": ["MUTUAL FUND", "SIP", "DIVIDEND"],
      "patterns": ["\\bSIP\\b", ".*MUTUAL.*FUND.*"]
    },
    "Education": {
      "exact": ["FEES", "TUITION", "SCHOOL FEES", "COLLEGE"],
      "patterns": ["\\bTUITION\\b", ".*FEES.*"]
    }
  },
  "credit_rules": {
    "Inward Bounce": {
      "exact": [
        "I/W RETURN",
        "INWARD RETURN",
        "INW RETURN",
        "INW RET",
        "CHQ DEP RETURN",
        "CHEQUE DEP RETURN",
        "CHEQUE DEPOSIT RETURN",
        "CHEQUE RETURNED",
        "RETURNED CHEQUE",
        "CREDIT RETURN",
        "DEPOSIT RETURN",
        "INWARD BOUNCE",
        "INW BOUNCE",
        "CLG RETURN",
        "CLEARING RETURN"
      ],
      "patterns": [
        "(I/W|INW|INWARD)\\s*(RETURN|RET|CHQ RET|BOUNCE)",
        "(CLG|CLEARING)\\s*(RETURN|RET)"
      ]
    },
    "Salary": {
      "exact": [
        "SALARY",
        "SAL CR",
        "PAYROLL",
        "WAGES",
        "STIPEND"
      ],
      "patterns": [
        "SALARY.*",
        "SAL.*CREDIT.*",
        "PAYROLL.*"
      ]
    },
    "Refund": {
      "exact": ["UPI/CREDIT ADJUSTMENT"],
      "patterns": []
    },
    "Interest Income": {
      "exact": [
        "MONTHLY SAVINGS INTEREST CREDIT",
        "MONTHLY SAVINGS INTEREST CREDI T"
      ],
      "patterns": []
    },
    "Transfer": {
      "exact": [
        "IMPS-MOB/FUND TRF",
        "IMPS-INET/FUND TRF",
        "NEFT/",
        "PAYMENT FROM PHONEPE",
        "UPI TRANSACTION FOR PPPL",
        "MANDATE REQUEST"
      ],
      "patterns": []
    }
  },
  "amount_heuristics": {
    "emi": {
      "enabled": true,
      "debit_only": true,
      "min_amount": 500,
      "max_amount": 100000,
      "multiple_of": 100,
      "description_tokens": [
        "emi",
        "loan",
        "installment"
      ],
      "category": "Loan Payment",
      "matched_rule": "amount_emi",
      "token_case": "lower"
    },
    "salary": {
      "enabled": true,
      "credit_only": true,
      "min_amount": 10000,
      "multiple_of": 1000,
      "description_tokens": [
        "salary",
        "payroll",
        "wages"
      ],
      "category": "Salary",
      "matched_rule": "amount_salary",
      "token_case": "lower"
    }
  }
}
